{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/research-package-update-readiness-review-v1.json",
  "title": "Turing Research Package Update Readiness Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "review_scope",
    "readiness_status",
    "package_axes",
    "metadata_axes",
    "rollback_migration_axes",
    "fixture_policy_axes",
    "security_release_axes",
    "owner_review_axes",
    "rejection_rules",
    "unsupported_boundaries",
    "validation_commands"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "review_id": {
      "type": "string",
      "pattern": "^REL\\.UPDATE_READINESS_REVIEW\\.[A-Z0-9._-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "no_claim_research_package_update_readiness_template",
        "draft",
        "reviewed",
        "superseded"
      ]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": {
      "type": "string",
      "minLength": 180
    },
    "source_records": {
      "type": "array",
      "minItems": 16,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lab_package",
        "reference_platform",
        "fixture_policy",
        "owner_reviewer",
        "independent_reviewer",
        "release_operations_reviewer",
        "security_reviewer",
        "privacy_reviewer",
        "review_status",
        "prohibited_placeholder_policy"
      ],
      "properties": {
        "lab_package": { "type": ["string", "null"] },
        "reference_platform": { "type": ["string", "null"] },
        "fixture_policy": { "type": ["string", "null"] },
        "owner_reviewer": { "type": ["string", "null"] },
        "independent_reviewer": { "type": ["string", "null"] },
        "release_operations_reviewer": { "type": ["string", "null"] },
        "security_reviewer": { "type": ["string", "null"] },
        "privacy_reviewer": { "type": ["string", "null"] },
        "review_status": {
          "type": "string",
          "enum": [
            "template_only_no_review",
            "draft_review",
            "owner_reviewed",
            "rejected"
          ]
        },
        "prohibited_placeholder_policy": {
          "type": "string",
          "minLength": 80
        }
      }
    },
    "readiness_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_reviewed",
        "independent_reviewed",
        "release_operations_reviewed",
        "security_reviewed",
        "privacy_reviewed",
        "executable_package_manifest_reviewed",
        "update_metadata_parser_reviewed",
        "signature_threshold_tests_passed",
        "staged_install_tests_passed",
        "tamper_replay_tests_passed",
        "partial_write_fault_tests_passed",
        "rollback_migration_tests_passed",
        "privacy_event_reviewed",
        "production_key_separation_reviewed",
        "release_readiness_approved",
        "supported_security_approved",
        "production_updater_approved",
        "stable_channel_approved",
        "public_distribution_approved",
        "implementation_claim_supported"
      ],
      "properties": {
        "owner_reviewed": { "type": "boolean" },
        "independent_reviewed": { "type": "boolean" },
        "release_operations_reviewed": { "type": "boolean" },
        "security_reviewed": { "type": "boolean" },
        "privacy_reviewed": { "type": "boolean" },
        "executable_package_manifest_reviewed": { "type": "boolean" },
        "update_metadata_parser_reviewed": { "type": "boolean" },
        "signature_threshold_tests_passed": { "type": "boolean" },
        "staged_install_tests_passed": { "type": "boolean" },
        "tamper_replay_tests_passed": { "type": "boolean" },
        "partial_write_fault_tests_passed": { "type": "boolean" },
        "rollback_migration_tests_passed": { "type": "boolean" },
        "privacy_event_reviewed": { "type": "boolean" },
        "production_key_separation_reviewed": { "type": "boolean" },
        "release_readiness_approved": { "type": "boolean" },
        "supported_security_approved": { "type": "boolean" },
        "production_updater_approved": { "type": "boolean" },
        "stable_channel_approved": { "type": "boolean" },
        "public_distribution_approved": { "type": "boolean" },
        "implementation_claim_supported": { "type": "boolean" }
      }
    },
    "package_axes": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "metadata_axes": {
      "type": "array",
      "minItems": 13,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "rollback_migration_axes": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "fixture_policy_axes": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "security_release_axes": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "owner_review_axes": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/rejection_rule" }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 16,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "$defs": {
    "evidence_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "required_evidence", "template_status"],
      "properties": {
        "axis": {
          "type": "string",
          "minLength": 3
        },
        "required_evidence": {
          "type": "string",
          "minLength": 20
        },
        "template_status": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "rejection_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "condition", "outcome"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reject_[a-z0-9_]+$"
        },
        "condition": {
          "type": "string",
          "minLength": 20
        },
        "outcome": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  }
}
