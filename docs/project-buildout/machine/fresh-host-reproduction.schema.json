{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/fresh-host-reproduction-v1.json",
  "title": "Turing Fresh Host Reproduction Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "current_local_baseline",
    "required_reproduction_scope",
    "evidence_axes",
    "rejection_rules",
    "unsupported_boundaries"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "inventory_id": {
      "type": "string",
      "pattern": "^BUILD\\.FRESH_HOST\\.[A-Z0-9._-]+$"
    },
    "status": {
      "enum": ["no_claim_fresh_host_reproduction_inventory"]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": { "type": "string" },
    "source_records": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "current_local_baseline": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "required_reproduction_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_scope", "source_scope", "command_scope", "artifact_scope"],
      "properties": {
        "host_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "source_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "command_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "artifact_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "evidence_axes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "evidence_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis_id", "name", "required_output", "missing_status"],
      "properties": {
        "axis_id": {
          "type": "string",
          "pattern": "^FRESH-HOST-AXIS-[A-Z0-9_]+$"
        },
        "name": { "type": "string" },
        "required_output": { "type": "string" },
        "missing_status": { "type": "string" }
      }
    }
  }
}
