{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/build-readiness-closure-review-v1.json",
  "title": "Turing Build Readiness Closure Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "closure_review_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "review_scope",
    "decision_records",
    "closure_status",
    "gate_axes",
    "owner_review_axes",
    "release_authority_axes",
    "readiness_lifecycle",
    "rejection_rules",
    "unsupported_boundaries",
    "validation_commands"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "closure_review_id": {
      "type": "string",
      "pattern": "^PB020\\.BUILD_READINESS_CLOSURE\\.[A-Z0-9._-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "no_claim_build_readiness_closure_template",
        "draft",
        "reviewed",
        "superseded"
      ]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": {
      "type": "string",
      "minLength": 160
    },
    "source_records": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "owner_reviewer",
        "independent_reviewer",
        "review_status",
        "prohibited_placeholder_policy"
      ],
      "properties": {
        "scope": {
          "type": ["string", "null"]
        },
        "owner_reviewer": {
          "type": ["string", "null"]
        },
        "independent_reviewer": {
          "type": ["string", "null"]
        },
        "review_status": {
          "type": "string",
          "enum": [
            "template_only_no_review",
            "draft_review",
            "owner_reviewed",
            "rejected"
          ]
        },
        "prohibited_placeholder_policy": {
          "type": "string",
          "minLength": 80
        }
      }
    },
    "decision_records": {
      "type": "array",
      "minItems": 11,
      "items": {
        "$ref": "#/$defs/decision_record"
      }
    },
    "closure_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_reviewed",
        "independent_reviewed",
        "all_pb_gates_closed",
        "all_tasks_approved",
        "all_information_ready_for_building",
        "broad_m1_authorized",
        "release_authority_granted",
        "production_authority_granted",
        "security_claim_supported",
        "performance_claim_supported",
        "compatibility_claim_supported",
        "accessibility_claim_supported",
        "daily_driver_claim_supported"
      ],
      "properties": {
        "owner_reviewed": { "type": "boolean" },
        "independent_reviewed": { "type": "boolean" },
        "all_pb_gates_closed": { "type": "boolean" },
        "all_tasks_approved": { "type": "boolean" },
        "all_information_ready_for_building": { "type": "boolean" },
        "broad_m1_authorized": { "type": "boolean" },
        "release_authority_granted": { "type": "boolean" },
        "production_authority_granted": { "type": "boolean" },
        "security_claim_supported": { "type": "boolean" },
        "performance_claim_supported": { "type": "boolean" },
        "compatibility_claim_supported": { "type": "boolean" },
        "accessibility_claim_supported": { "type": "boolean" },
        "daily_driver_claim_supported": { "type": "boolean" }
      }
    },
    "gate_axes": {
      "type": "array",
      "minItems": 10,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "owner_review_axes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "release_authority_axes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "readiness_lifecycle": {
      "type": "array",
      "minItems": 12,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 16,
      "items": {
        "$ref": "#/$defs/rejection_rule"
      }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 16,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "packet_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_commit",
        "source_tree_digest",
        "registry_digest",
        "task_manifest_digest",
        "collected_at",
        "platform",
        "toolchain",
        "configuration"
      ],
      "properties": {
        "source_commit": { "type": "string", "minLength": 7 },
        "source_tree_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "registry_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "task_manifest_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "collected_at": { "type": "string", "format": "date-time" },
        "platform": { "type": "string", "minLength": 3 },
        "toolchain": { "type": "string", "minLength": 3 },
        "configuration": { "type": "string", "minLength": 3 }
      }
    }
  },
  "$defs": {
    "evidence_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "required_evidence", "template_status"],
      "properties": {
        "axis": {
          "type": "string",
          "minLength": 3
        },
        "required_evidence": {
          "type": "string",
          "minLength": 20
        },
        "template_status": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_scope",
        "status",
        "decision",
        "rationale",
        "owner",
        "independent_reviewer",
        "evidence_refs",
        "unresolved_limitations",
        "exception",
        "registry_updates"
      ],
      "properties": {
        "decision_record_id": { "type": "string", "minLength": 3 },
        "gate_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "status": {
          "type": "string",
          "enum": ["unresolved_template", "selected", "rejected", "held"]
        },
        "decision": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "independent_reviewer": { "type": ["string", "null"] },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        },
        "evidence_digests": {
          "type": "array",
          "items": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "validator_results": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        },
        "prohibited_claims": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        },
        "authority_granted": { "type": "boolean" },
        "unresolved_limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        },
        "exception": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "owner",
            "risk_refs",
            "expires_at",
            "rollback",
            "support_boundary_change"
          ],
          "properties": {
            "status": { "type": "string", "minLength": 3 },
            "owner": { "type": ["string", "null"] },
            "risk_refs": {
              "type": "array",
              "items": { "type": "string", "minLength": 3 }
            },
            "expires_at": { "type": ["string", "null"], "format": "date" },
            "rollback": { "type": ["string", "null"] },
            "support_boundary_change": { "type": ["string", "null"] }
          }
        },
        "registry_updates": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        }
      }
    },
    "rejection_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "condition", "outcome"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reject_[a-z0-9_]+$"
        },
        "condition": {
          "type": "string",
          "minLength": 20
        },
        "outcome": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  }
}
