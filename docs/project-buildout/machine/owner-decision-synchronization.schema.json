{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/owner-decision-synchronization-v1.json",
  "title": "Turing Owner Decision Synchronization Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix_id", "status", "updated", "claim_status", "related_records", "decision_scopes", "validation_commands", "unsupported"],
  "properties": {
    "schema_version": { "const": 1 },
    "matrix_id": { "type": "string", "pattern": "^PB020\\.OWNER_DECISION_SYNC\\.[A-Z0-9._-]+$" },
    "status": { "const": "no_claim_owner_decision_synchronization_matrix" },
    "updated": { "type": "string", "format": "date" },
    "claim_status": { "type": "string", "minLength": 160 },
    "related_records": { "type": "array", "minItems": 8, "items": { "type": "string", "minLength": 3 } },
    "decision_scopes": { "type": "array", "minItems": 11, "items": { "$ref": "#/$defs/scope" } },
    "validation_commands": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 3 } },
    "unsupported": { "type": "array", "minItems": 8, "items": { "type": "string", "minLength": 10 } }
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_id", "gate_scope", "owner_role", "independent_reviewer_role", "required_evidence", "required_synchronization", "exception_policy", "prohibited_until"],
      "properties": {
        "scope_id": { "type": "string", "pattern": "^OWNER-SYNC-[0-9]{2}$" },
        "gate_scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
        "owner_role": { "type": "string", "minLength": 3 },
        "independent_reviewer_role": { "type": "string", "minLength": 3 },
        "required_evidence": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 10 } },
        "required_synchronization": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 3 } },
        "exception_policy": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 10 } },
        "prohibited_until": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 10 } }
      }
    }
  }
}
