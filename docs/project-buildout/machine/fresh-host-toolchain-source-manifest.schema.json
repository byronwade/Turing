{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/fresh-host-toolchain-source-manifest-v1.json",
  "title": "Turing Fresh-Host Toolchain Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "status", "updated", "related_gates", "claim_status", "evidence_axes", "sources", "source_documents", "unsupported"],
  "properties": {
    "schema_version": { "const": 1 },
    "manifest_id": { "type": "string", "pattern": "^BUILD\\.FRESH_HOST\\.SOURCES\\.[A-Z0-9._-]+$" },
    "status": { "const": "no_claim_toolchain_source_manifest" },
    "updated": { "type": "string", "format": "date" },
    "related_gates": { "type": "array", "minItems": 2, "items": { "enum": ["PB-008", "PB-009"] } },
    "claim_status": { "type": "string", "minLength": 1 },
    "evidence_axes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "source_documents": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "unsupported": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "title", "publisher", "url", "retrieved", "observation", "run_record_consequence"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^BUILD-SOURCE-[A-Z0-9._-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "retrieved": { "type": "string", "format": "date" },
        "observation": { "type": "string", "minLength": 1 },
        "run_record_consequence": { "type": "string", "minLength": 1 }
      }
    }
  }
}
