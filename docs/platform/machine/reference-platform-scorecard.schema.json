{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/reference-platform-scorecard-v1.json",
  "title": "Turing Reference Desktop Platform Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scorecard_id", "status", "updated", "related_gates", "claim_status", "evidence_dimensions", "sources", "candidates", "source_documents", "unsupported"],
  "properties": {
    "schema_version": { "const": 1 },
    "scorecard_id": { "type": "string", "pattern": "^PLATFORM\\.PB006\\.REFERENCE_DESKTOP\\.[A-Z0-9._-]+$" },
    "status": { "const": "no_claim_reference_platform_scorecard" },
    "updated": { "type": "string", "format": "date" },
    "related_gates": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^PB-[0-9]{3}$" } },
    "claim_status": { "type": "string", "minLength": 1 },
    "evidence_dimensions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "candidates": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/candidate" } },
    "source_documents": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "unsupported": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "platform", "title", "publisher", "url", "retrieved", "observation", "evidence_consequence"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^PLAT-SOURCE-[A-Z0-9._-]+$" },
        "platform": { "enum": ["cross-platform", "windows", "macos", "linux"] },
        "title": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "retrieved": { "type": "string", "format": "date" },
        "observation": { "type": "string", "minLength": 1 },
        "evidence_consequence": { "type": "string", "minLength": 1 }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "platform", "architecture", "selection_status", "source_ids", "required_evidence", "open_questions"],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^reference-[a-z0-9-]+$" },
        "platform": { "enum": ["windows", "macos", "linux"] },
        "architecture": { "type": "string", "minLength": 1 },
        "selection_status": { "const": "not_selected" },
        "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "required_evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "open_questions": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
