{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/profile-session-readiness-review-v1.json",
  "title": "Turing Profile Session Readiness Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "review_scope",
    "readiness_status",
    "format_axes",
    "behavior_axes",
    "migration_axes",
    "fixture_policy_axes",
    "privacy_axes",
    "owner_review_axes",
    "rejection_rules",
    "unsupported_boundaries",
    "validation_commands"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "review_id": {
      "type": "string",
      "pattern": "^PROFILE_SESSION\\.READINESS_REVIEW\\.[A-Z0-9._-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "no_claim_profile_session_readiness_template",
        "draft",
        "reviewed",
        "superseded"
      ]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": {
      "type": "string",
      "minLength": 160
    },
    "source_records": {
      "type": "array",
      "minItems": 16,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_package",
        "reference_platform",
        "fixture_policy",
        "owner_reviewer",
        "independent_reviewer",
        "privacy_reviewer",
        "review_status",
        "prohibited_placeholder_policy"
      ],
      "properties": {
        "schema_package": { "type": ["string", "null"] },
        "reference_platform": { "type": ["string", "null"] },
        "fixture_policy": { "type": ["string", "null"] },
        "owner_reviewer": { "type": ["string", "null"] },
        "independent_reviewer": { "type": ["string", "null"] },
        "privacy_reviewer": { "type": ["string", "null"] },
        "review_status": {
          "type": "string",
          "enum": [
            "template_only_no_review",
            "draft_review",
            "owner_reviewed",
            "rejected"
          ]
        },
        "prohibited_placeholder_policy": {
          "type": "string",
          "minLength": 80
        }
      }
    },
    "readiness_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_reviewed",
        "independent_reviewed",
        "privacy_reviewed",
        "executable_profile_schema_reviewed",
        "executable_space_schema_reviewed",
        "executable_session_schema_reviewed",
        "executable_snapshot_schema_reviewed",
        "executable_migration_schema_reviewed",
        "migration_tests_passed",
        "fault_tests_passed",
        "real_profile_fixture_approved",
        "private_session_behavior_supported",
        "protected_work_behavior_supported",
        "data_loss_safety_supported",
        "user_data_handling_ready",
        "production_profile_format_approved",
        "sync_supported",
        "credential_storage_supported",
        "release_path_approved",
        "implementation_claim_supported"
      ],
      "properties": {
        "owner_reviewed": { "type": "boolean" },
        "independent_reviewed": { "type": "boolean" },
        "privacy_reviewed": { "type": "boolean" },
        "executable_profile_schema_reviewed": { "type": "boolean" },
        "executable_space_schema_reviewed": { "type": "boolean" },
        "executable_session_schema_reviewed": { "type": "boolean" },
        "executable_snapshot_schema_reviewed": { "type": "boolean" },
        "executable_migration_schema_reviewed": { "type": "boolean" },
        "migration_tests_passed": { "type": "boolean" },
        "fault_tests_passed": { "type": "boolean" },
        "real_profile_fixture_approved": { "type": "boolean" },
        "private_session_behavior_supported": { "type": "boolean" },
        "protected_work_behavior_supported": { "type": "boolean" },
        "data_loss_safety_supported": { "type": "boolean" },
        "user_data_handling_ready": { "type": "boolean" },
        "production_profile_format_approved": { "type": "boolean" },
        "sync_supported": { "type": "boolean" },
        "credential_storage_supported": { "type": "boolean" },
        "release_path_approved": { "type": "boolean" },
        "implementation_claim_supported": { "type": "boolean" }
      }
    },
    "format_axes": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "behavior_axes": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "migration_axes": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "fixture_policy_axes": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "privacy_axes": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "owner_review_axes": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/rejection_rule" }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "$defs": {
    "evidence_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "required_evidence", "template_status"],
      "properties": {
        "axis": {
          "type": "string",
          "minLength": 3
        },
        "required_evidence": {
          "type": "string",
          "minLength": 20
        },
        "template_status": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "rejection_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "condition", "outcome"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reject_[a-z0-9_]+$"
        },
        "condition": {
          "type": "string",
          "minLength": 20
        },
        "outcome": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  }
}
