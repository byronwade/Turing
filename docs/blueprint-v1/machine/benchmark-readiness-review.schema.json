{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/benchmark-readiness-review-v1.json",
  "title": "Turing Benchmark Readiness Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "review_scope",
    "readiness_status",
    "hardware_os_axes",
    "corpus_network_axes",
    "runner_artifact_axes",
    "browser_pin_comparison_axes",
    "statistics_denominator_axes",
    "claim_review_axes",
    "rejection_rules",
    "unsupported_boundaries",
    "validation_commands"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "review_id": {
      "type": "string",
      "pattern": "^TURING\\.BENCHMARK\\.READINESS_REVIEW\\.[A-Z0-9._-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "no_claim_benchmark_readiness_template",
        "draft",
        "reviewed",
        "rejected",
        "superseded"
      ]
    },
    "updated": { "type": "string", "format": "date" },
    "claim_status": { "type": "string", "minLength": 180 },
    "source_records": {
      "type": "array",
      "minItems": 30,
      "items": { "type": "string", "minLength": 3 }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_manifest",
        "hardware_tiers",
        "os_controls",
        "corpus",
        "network_profile",
        "launch_runner",
        "artifact_package",
        "browser_pins",
        "claim_bundle",
        "owner_reviewer",
        "performance_reviewer",
        "benchmark_operations_reviewer",
        "quality_reviewer",
        "security_reviewer",
        "accessibility_reviewer",
        "release_operations_reviewer",
        "review_status",
        "prohibited_placeholder_policy"
      ],
      "properties": {
        "benchmark_manifest": { "type": ["string", "null"] },
        "hardware_tiers": { "type": ["string", "null"] },
        "os_controls": { "type": ["string", "null"] },
        "corpus": { "type": ["string", "null"] },
        "network_profile": { "type": ["string", "null"] },
        "launch_runner": { "type": ["string", "null"] },
        "artifact_package": { "type": ["string", "null"] },
        "browser_pins": { "type": ["string", "null"] },
        "claim_bundle": { "type": ["string", "null"] },
        "owner_reviewer": { "type": ["string", "null"] },
        "performance_reviewer": { "type": ["string", "null"] },
        "benchmark_operations_reviewer": { "type": ["string", "null"] },
        "quality_reviewer": { "type": ["string", "null"] },
        "security_reviewer": { "type": ["string", "null"] },
        "accessibility_reviewer": { "type": ["string", "null"] },
        "release_operations_reviewer": { "type": ["string", "null"] },
        "review_status": {
          "type": "string",
          "enum": [
            "template_only_no_review",
            "draft_review",
            "owner_reviewed",
            "rejected"
          ]
        },
        "prohibited_placeholder_policy": { "type": "string", "minLength": 80 }
      }
    },
    "readiness_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_reviewed",
        "performance_reviewed",
        "benchmark_operations_reviewed",
        "quality_reviewed",
        "security_reviewed",
        "accessibility_reviewed",
        "release_operations_reviewed",
        "hardware_tiers_reviewed",
        "os_controls_reviewed",
        "corpus_reviewed",
        "network_profiles_reviewed",
        "server_evidence_reviewed",
        "launch_runner_reviewed",
        "browser_pins_reviewed",
        "trace_artifacts_reviewed",
        "raw_results_reviewed",
        "thirty_tab_artifacts_reviewed",
        "statistics_reviewed",
        "denominator_reviewed",
        "resource_attribution_reviewed",
        "equal_workload_reviewed",
        "claim_bundle_reviewed",
        "benchmark_ready_supported",
        "public_performance_claim_supported",
        "faster_claim_supported",
        "lower_memory_claim_supported",
        "lower_energy_claim_supported",
        "chrome_class_claim_supported",
        "competitor_result_supported",
        "daily_driver_claim_supported",
        "production_claim_supported",
        "implementation_claim_supported"
      ],
      "properties": {
        "owner_reviewed": { "type": "boolean" },
        "performance_reviewed": { "type": "boolean" },
        "benchmark_operations_reviewed": { "type": "boolean" },
        "quality_reviewed": { "type": "boolean" },
        "security_reviewed": { "type": "boolean" },
        "accessibility_reviewed": { "type": "boolean" },
        "release_operations_reviewed": { "type": "boolean" },
        "hardware_tiers_reviewed": { "type": "boolean" },
        "os_controls_reviewed": { "type": "boolean" },
        "corpus_reviewed": { "type": "boolean" },
        "network_profiles_reviewed": { "type": "boolean" },
        "server_evidence_reviewed": { "type": "boolean" },
        "launch_runner_reviewed": { "type": "boolean" },
        "browser_pins_reviewed": { "type": "boolean" },
        "trace_artifacts_reviewed": { "type": "boolean" },
        "raw_results_reviewed": { "type": "boolean" },
        "thirty_tab_artifacts_reviewed": { "type": "boolean" },
        "statistics_reviewed": { "type": "boolean" },
        "denominator_reviewed": { "type": "boolean" },
        "resource_attribution_reviewed": { "type": "boolean" },
        "equal_workload_reviewed": { "type": "boolean" },
        "claim_bundle_reviewed": { "type": "boolean" },
        "benchmark_ready_supported": { "type": "boolean" },
        "public_performance_claim_supported": { "type": "boolean" },
        "faster_claim_supported": { "type": "boolean" },
        "lower_memory_claim_supported": { "type": "boolean" },
        "lower_energy_claim_supported": { "type": "boolean" },
        "chrome_class_claim_supported": { "type": "boolean" },
        "competitor_result_supported": { "type": "boolean" },
        "daily_driver_claim_supported": { "type": "boolean" },
        "production_claim_supported": { "type": "boolean" },
        "implementation_claim_supported": { "type": "boolean" }
      }
    },
    "hardware_os_axes": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "corpus_network_axes": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "runner_artifact_axes": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "browser_pin_comparison_axes": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "statistics_denominator_axes": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "claim_review_axes": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/evidence_axis" }
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/rejection_rule" }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 14,
      "items": { "type": "string", "minLength": 10 }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "$defs": {
    "evidence_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "required_evidence", "template_status"],
      "properties": {
        "axis": { "type": "string", "minLength": 3 },
        "required_evidence": { "type": "string", "minLength": 20 },
        "template_status": { "type": "string", "minLength": 10 }
      }
    },
    "rejection_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "condition", "outcome"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reject_[a-z0-9_]+$"
        },
        "condition": { "type": "string", "minLength": 20 },
        "outcome": { "type": "string", "minLength": 20 }
      }
    }
  }
}
