  "attribution_rules": [
    {
      "id": "direct",
      "description": "Charge resource use to the principal that owns the allocation, task, handle, request, or surface."
    },
    {
      "id": "sampled",
      "description": "Use sampled stack, trace, or heap evidence only when direct ownership is unavailable; keep confidence visible."
    },
    {
      "id": "shared_charged",
      "description": "Report physical shared totals once and separately charge proportional or policy-defined owner views."
    },
    {
      "id": "unknown",
      "description": "Keep unattributed resources in an explicit unknown bucket with reduction work before claims."
    }
  ],
  "shared_resource_policy": {
    "physical_total_rule": "shared resources appear once in physical totals",
    "charged_total_rule": "charged views may sum to the shared physical total only under a documented proportional or first-owner policy",
    "privacy_rule": "cross-profile sharing requires policy and privacy equivalence before attribution is merged",
    "claim_rule": "memory or energy claims must disclose physical totals, charged totals, unknown totals, and shared-resource policy"
  },
  "collection_plan": {
    "minimum_browser_trace_fields": [
      "monotonic_timestamp",
      "process_id",
      "thread_id",
