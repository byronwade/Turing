      "CPU scheduling and execution samples",
      "GPU memory/activity counters where available",
      "disk and network I/O counters",
      "wakeups and power or energy proxy counters"
    ],
    "unsupported_collection": [
      "no current Turing browser emits these trace fields",
      "no current runner collects platform counters by owner",
      "no current UI exposes the attribution contract"
    ]
  },
  "ui_reporting_contract": {
    "required_views": [
      "per-tab",
      "per-profile",
      "per-site",
      "per-process",
      "shared-service",
      "unknown"
    ],
    "required_disclosures": [
      "physical versus charged memory",
      "known versus estimated values",
      "unknown bucket",
      "lifecycle state",
      "discarded or frozen state",
      "security configuration",
      "unsupported counters"
    ],
    "prohibited_ui_claims": [
      "do not sum double-counted shared memory as physical memory",
      "do not hide unknown resources",
      "do not present estimated energy as measured battery draw",
      "do not compare browsers when unsupported counters differ materially"
    ]
  },
  "unsupported_behavior": [
    "taxonomy only; no instrumentation exists",
