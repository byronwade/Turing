{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/research-question-coverage-v1.json",
  "title": "Turing Research Question Coverage Audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "audit_id", "status", "updated", "claim_status", "program_source", "crosswalk_source", "progress_snapshot_source", "active_question_ids", "deferred_questions", "validation_commands", "unsupported"],
  "properties": {
    "schema_version": { "const": 1 },
    "audit_id": { "type": "string", "pattern": "^RESEARCH\\.QUESTION_COVERAGE\\.[A-Z0-9._-]+$" },
    "status": { "const": "no_claim_research_question_coverage_audit" },
    "updated": { "type": "string", "format": "date" },
    "claim_status": { "type": "string", "minLength": 160 },
    "program_source": { "type": "string", "minLength": 3 },
    "crosswalk_source": { "type": "string", "minLength": 3 },
    "progress_snapshot_source": { "type": "string", "minLength": 3 },
    "active_question_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^RQ-[0-9]{2}$" } },
    "deferred_questions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/deferred" } },
    "validation_commands": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 3 } },
    "unsupported": { "type": "array", "minItems": 8, "items": { "type": "string", "minLength": 10 } }
  },
  "$defs": {
    "deferred": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "status", "reason", "owner_route", "revisit_trigger", "required_future_evidence"],
      "properties": {
        "question_id": { "type": "string", "pattern": "^RQ-[0-9]{2}$" },
        "status": { "const": "deferred_outside_current_prebuild_crosswalk" },
        "reason": { "type": "string", "minLength": 40 },
        "owner_route": { "type": "string", "minLength": 20 },
        "revisit_trigger": { "type": "string", "minLength": 30 },
        "required_future_evidence": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 10 } }
      }
    }
  }
}
