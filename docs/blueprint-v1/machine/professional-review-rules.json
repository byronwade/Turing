{
  "schema_version": 1,
  "rules": [
    {
      "id": "REV-ROUTINE",
      "match": "low-risk internal behavior",
      "artifacts": [
        "tests",
        "documentation impact"
      ],
      "reviewers": [
        "owner"
      ],
      "minimum_approvals": 1
    },
    {
      "id": "REV-SECURITY",
      "match": "trust boundary, parser, IPC, permission, credential, update, Plug-in, DevTools, automation, or agent change",
      "artifacts": [
        "threat-model delta",
        "negative tests",
        "security review"
      ],
      "reviewers": [
        "owner",
        "security"
      ],
      "minimum_approvals": 2
    },
    {
      "id": "REV-PUBLIC-API",
      "match": "public API, ABI, schema, profile, policy, Plug-in, embedding, or compatibility change",
      "artifacts": [
        "RFC",
        "compatibility tests",
        "migration"
      ],
      "reviewers": [
        "owner",
        "api-protocol",
        "architecture"
      ],
      "minimum_approvals": 2
    },
    {
      "id": "REV-PERFORMANCE",
      "match": "hot path, allocator, scheduler, memory layout, GPU, startup, or benchmark claim",
      "artifacts": [
        "performance plan",
        "raw evidence",
        "guardrails"
      ],
      "reviewers": [
        "owner",
        "performance"
      ],
      "minimum_approvals": 2
    },
    {
      "id": "REV-RELEASE",
      "match": "signing, update, release trust, supported-version, or irreversible migration",
      "artifacts": [
        "RFC",
        "threat model",
        "rollout/rollback",
        "release readiness"
      ],
      "reviewers": [
        "owner",
        "security",
        "release-operations",
        "architecture"
      ],
      "minimum_approvals": 3
    },
    {
      "id": "REV-MARKET",
      "match": "market opportunity, product positioning, competitor comparison, migration, workspace, sync, collaboration, resource UX, or product-level AI proposal",
      "artifacts": [
        "market opportunity",
        "source and method",
        "contrary evidence",
        "validation plan",
        "cross-cutting review",
        "expiry"
      ],
      "reviewers": [
        "owner",
        "market-strategy",
        "product",
        "security",
        "accessibility"
      ],
      "minimum_approvals": 2
    },
    {
      "id": "REV-UI-RUNTIME",
      "match": "native UI framework, toolkit adapter, design tokens, shell components, page surfaces, input/IME, accessibility bridge, UI backend/renderer, React design lab, or UI footprint change",
      "artifacts": [
        "UI framework experiment or design note",
        "adapter conformance",
        "accessibility evidence",
        "page-surface evidence when applicable",
        "binary/memory/latency evidence for hot paths",
        "license and dependency review",
        "replacement plan"
      ],
      "reviewers": [
        "owner",
        "ui-runtime",
        "architecture",
        "security",
        "performance",
        "accessibility",
        "platform",
        "product"
      ],
      "minimum_approvals": 2
    },
    {
      "id": "REV-AGENT-EXECUTION",
      "match": "agent authority, task manifest, tool/network/credential scope, run provenance, independent verification, escalation, or agent-generated production change",
      "artifacts": [
        "task manifest",
        "run manifest",
        "evidence bundle",
        "independent review",
        "rollback",
        "authority audit"
      ],
      "reviewers": [
        "owner",
        "agent-operations",
        "security",
        "quality",
        "architecture"
      ],
      "minimum_approvals": 2
    },
    {
      "id": "REV-PRODUCTION-READINESS",
      "match": "stable scope, supported platform, release channel, SLO, update trust, vulnerability SLA, service dependency, support, signing, legal, or production promotion",
      "artifacts": [
        "production readiness review",
        "release gates",
        "SLO evidence",
        "security and accessibility evidence",
        "provenance",
        "rollback",
        "support and legal approval"
      ],
      "reviewers": [
        "owner",
        "release-operations",
        "security",
        "quality",
        "accessibility",
        "support",
        "legal-community",
        "human-release-authority"
      ],
      "minimum_approvals": 3
    }
  ]
}
