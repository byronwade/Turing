{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.example/schemas/research-readiness-crosswalk.schema.json",
  "title": "Turing Research Readiness Crosswalk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated",
    "status",
    "source",
    "claim_status",
    "lanes"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"
    },
    "status": {
      "const": "no_claim_research_control"
    },
    "source": {
      "const": "docs/research/README.md#build-readiness-research-crosswalk"
    },
    "claim_status": {
      "type": "string",
      "minLength": 1
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "readiness_items",
          "tasks",
          "requirements",
          "risks",
          "research_questions",
          "evidence_start",
          "next_proof",
          "claim_boundary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^research-lane-[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "readiness_items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^PB-[0-9]{3}$"
            }
          },
          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^TASK-[0-9]{6}$"
            }
          },
          "requirements": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^REQ-[A-Z0-9-]+$"
            }
          },
          "risks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^R-[0-9]{3}$"
            }
          },
          "research_questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^RQ-[0-9]{2}$"
            }
          },
          "evidence_start": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "next_proof": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "claim_boundary": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
