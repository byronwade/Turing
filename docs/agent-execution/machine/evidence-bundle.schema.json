{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.example/schemas/evidence-bundle.schema.json",
  "title": "Turing Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "task_id",
    "source_commit",
    "environment",
    "artifacts",
    "failures",
    "review"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^EVID-[0-9]{8}-[A-Z0-9-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{6}$"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "environment": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "path",
          "sha256",
          "result"
        ]
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": [
        "reviewer",
        "independent",
        "decision"
      ]
    }
  }
}
