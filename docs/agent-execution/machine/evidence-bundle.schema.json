{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.example/schemas/evidence-bundle.schema.json",
  "title": "Turing Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "task_id",
    "source_commit",
    "environment",
    "artifacts",
    "failures",
    "limitations",
    "review"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^EVID-[0-9]{8}-[A-Z0-9-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{6}$"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "environment": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "path",
          "sha256",
          "result"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["source_file", "github_actions_run", "command_log"]
          },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "result": { "type": "string", "minLength": 1 },
          "command_id": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "minLength": 1 },
          "source_commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string", "minLength": 1 },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "environment_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": [
        "reviewer",
        "independent",
        "decision"
      ]
    }
  }
}
