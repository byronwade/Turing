{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.example/schemas/execution-task.schema.json",
  "title": "Turing Agent Execution Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "status",
    "readiness_items",
    "owner",
    "independent_reviewer",
    "requirements",
    "risks",
    "work_packages",
    "allowed_paths",
    "prohibited_paths",
    "preconditions",
    "acceptance_criteria",
    "negative_tests",
    "resource_budget",
    "rollback",
    "dependencies"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{6}$"
    },
    "status": {
      "enum": [
        "proposed",
        "specified",
        "reviewed",
        "ready",
        "running",
        "evidence_pending",
        "review_pending",
        "accepted",
        "rejected",
        "rolled_back",
        "superseded"
      ]
    },
    "readiness_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^PB-[0-9]{3}$"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "independent_reviewer": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "work_packages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^WP-[0-9]{3}$"
      }
    },
    "adrs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "prohibited_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "negative_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resource_budget": {
      "type": "object",
      "required": [
        "wall_seconds",
        "cpu_seconds",
        "memory_bytes",
        "disk_bytes",
        "network_bytes",
        "max_workers",
        "max_retries"
      ]
    },
    "rollback": {
      "type": "object",
      "required": [
        "strategy",
        "evidence_required"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^TASK-[0-9]{6}$"
      }
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
