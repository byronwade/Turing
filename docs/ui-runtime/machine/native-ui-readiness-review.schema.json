{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/native-ui-readiness-review-v1.json",
  "title": "Turing Native UI Readiness Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "review_scope",
    "readiness_status",
    "gate_axes",
    "adapter_axes",
    "framework_axes",
    "page_surface_axes",
    "fixture_axes",
    "accessibility_axes",
    "release_exclusion_axes",
    "owner_review_axes",
    "rejection_rules",
    "unsupported_boundaries",
    "validation_commands"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "review_id": {
      "type": "string",
      "pattern": "^UI\\.READINESS_REVIEW\\.[A-Z0-9._-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "no_claim_native_ui_readiness_template",
        "draft",
        "reviewed",
        "superseded"
      ]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": {
      "type": "string",
      "minLength": 160
    },
    "source_records": {
      "type": "array",
      "minItems": 18,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_toolkit",
        "selected_adapter_strategy",
        "reference_platform",
        "owner_reviewer",
        "independent_reviewer",
        "review_status",
        "prohibited_placeholder_policy"
      ],
      "properties": {
        "selected_toolkit": { "type": ["string", "null"] },
        "selected_adapter_strategy": { "type": ["string", "null"] },
        "reference_platform": { "type": ["string", "null"] },
        "owner_reviewer": { "type": ["string", "null"] },
        "independent_reviewer": { "type": ["string", "null"] },
        "review_status": {
          "type": "string",
          "enum": [
            "template_only_no_review",
            "draft_review",
            "owner_reviewed",
            "rejected"
          ]
        },
        "prohibited_placeholder_policy": {
          "type": "string",
          "minLength": 80
        }
      }
    },
    "readiness_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_reviewed",
        "independent_reviewed",
        "adr_0013_accepted",
        "adr_0014_accepted",
        "adr_0016_accepted",
        "ui_gate_7_passed",
        "ui_gate_10_passed",
        "native_adapter_prototype_reviewed",
        "toolkit_selected",
        "trusted_chrome_ready",
        "accessibility_ready",
        "screen_reader_coverage_supported",
        "page_tree_proof_supported",
        "page_surface_approved",
        "compositor_ownership_decided",
        "release_path_ui_approved",
        "production_claim_supported",
        "implementation_claim_supported"
      ],
      "properties": {
        "owner_reviewed": { "type": "boolean" },
        "independent_reviewed": { "type": "boolean" },
        "adr_0013_accepted": { "type": "boolean" },
        "adr_0014_accepted": { "type": "boolean" },
        "adr_0016_accepted": { "type": "boolean" },
        "ui_gate_7_passed": { "type": "boolean" },
        "ui_gate_10_passed": { "type": "boolean" },
        "native_adapter_prototype_reviewed": { "type": "boolean" },
        "toolkit_selected": { "type": "boolean" },
        "trusted_chrome_ready": { "type": "boolean" },
        "accessibility_ready": { "type": "boolean" },
        "screen_reader_coverage_supported": { "type": "boolean" },
        "page_tree_proof_supported": { "type": "boolean" },
        "page_surface_approved": { "type": "boolean" },
        "compositor_ownership_decided": { "type": "boolean" },
        "release_path_ui_approved": { "type": "boolean" },
        "production_claim_supported": { "type": "boolean" },
        "implementation_claim_supported": { "type": "boolean" }
      }
    },
    "gate_axes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/gate_axis"
      }
    },
    "adapter_axes": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "framework_axes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "page_surface_axes": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "fixture_axes": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "accessibility_axes": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "release_exclusion_axes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "owner_review_axes": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/evidence_axis"
      }
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 13,
      "items": {
        "$ref": "#/$defs/rejection_rule"
      }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 18,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "$defs": {
    "gate_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "axis",
        "required_evidence",
        "template_status"
      ],
      "properties": {
        "gate_id": {
          "enum": ["PB-003", "PB-004", "PB-005", "PB-014", "PB-015"]
        },
        "axis": {
          "type": "string",
          "minLength": 3
        },
        "required_evidence": {
          "type": "string",
          "minLength": 30
        },
        "template_status": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "evidence_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "required_evidence", "template_status"],
      "properties": {
        "axis": {
          "type": "string",
          "minLength": 3
        },
        "required_evidence": {
          "type": "string",
          "minLength": 20
        },
        "template_status": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "rejection_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "condition", "outcome"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reject_[a-z0-9_]+$"
        },
        "condition": {
          "type": "string",
          "minLength": 20
        },
        "outcome": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  }
}
