{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/ui-adapter-contract-inventory-v1.json",
  "title": "Turing UI Adapter Contract Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "contract_areas",
    "current_model_invariants",
    "adapter_authority_denials",
    "required_evidence",
    "unsupported_boundaries"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "inventory_id": {
      "type": "string",
      "pattern": "^UI\\.ADAPTER\\.[A-Z0-9._-]+$"
    },
    "status": {
      "enum": [
        "no_claim_contract_inventory",
        "draft",
        "reviewed"
      ]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": {
      "type": "string"
    },
    "source_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "contract_areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contract_area"
      }
    },
    "current_model_invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/current_model_invariant"
      }
    },
    "adapter_authority_denials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapter_authority_denial"
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/required_evidence"
      }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "contract_area": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "area_id",
        "area",
        "owner_scope",
        "current_evidence",
        "required_contract",
        "missing_evidence"
      ],
      "properties": {
        "area_id": {
          "type": "string",
          "pattern": "^UI-ADAPTER-AREA-[A-Z0-9_-]+$"
        },
        "area": {
          "enum": [
            "state",
            "command",
            "surface",
            "accessibility",
            "diagnostic",
            "adapter"
          ]
        },
        "owner_scope": {
          "type": "string"
        },
        "current_evidence": {
          "type": "string"
        },
        "required_contract": {
          "type": "string"
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    },
    "current_model_invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariant_id",
        "invariant",
        "source",
        "still_missing"
      ],
      "properties": {
        "invariant_id": {
          "type": "string",
          "pattern": "^UI-ADAPTER-INVARIANT-[A-Z0-9_-]+$"
        },
        "invariant": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "still_missing": {
          "type": "string"
        }
      }
    },
    "adapter_authority_denial": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "denial_id",
        "authority",
        "denial_rule",
        "required_negative_evidence",
        "missing_evidence"
      ],
      "properties": {
        "denial_id": {
          "type": "string",
          "pattern": "^UI-ADAPTER-DENIAL-[A-Z0-9_-]+$"
        },
        "authority": {
          "enum": [
            "navigation",
            "profile",
            "permission",
            "credential",
            "agent",
            "Plug-in",
            "persistence",
            "update"
          ]
        },
        "denial_rule": {
          "type": "string"
        },
        "required_negative_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    },
    "required_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "name",
        "needed_for",
        "current_status",
        "missing_evidence"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^UI-ADAPTER-EV-[A-Z0-9_-]+$"
        },
        "name": {
          "type": "string"
        },
        "needed_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "current_status": {
          "enum": [
            "planning_only",
            "missing_adr",
            "missing_contract",
            "missing_adapter",
            "missing_negative_tests",
            "missing_owner_review"
          ]
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    }
  }
}
