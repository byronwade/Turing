{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turing.invalid/schemas/page-surface-composition-v1.json",
  "title": "Turing Page Surface Composition Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "status",
    "updated",
    "claim_status",
    "source_records",
    "surface_contract_fields",
    "composition_alternatives",
    "workflow_test_matrix",
    "failure_recovery_cases",
    "security_identity_boundaries",
    "evidence_blockers",
    "unsupported_boundaries"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "inventory_id": {
      "type": "string",
      "pattern": "^UI\\.SURFACE\\.[A-Z0-9._-]+$"
    },
    "status": {
      "enum": [
        "no_claim_surface_inventory",
        "draft",
        "reviewed"
      ]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "claim_status": {
      "type": "string"
    },
    "source_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "surface_contract_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface_contract_field"
      }
    },
    "composition_alternatives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/composition_alternative"
      }
    },
    "workflow_test_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow_test"
      }
    },
    "failure_recovery_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/failure_recovery_case"
      }
    },
    "security_identity_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/security_identity_boundary"
      }
    },
    "evidence_blockers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_blocker"
      }
    },
    "unsupported_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "surface_contract_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "purpose",
        "missing_evidence"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    },
    "composition_alternative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alternative_id",
        "name",
        "ownership_model",
        "required_evidence",
        "current_status",
        "missing_evidence"
      ],
      "properties": {
        "alternative_id": {
          "type": "string",
          "pattern": "^UI-SURFACE-ALT-[A-Z0-9_-]+$"
        },
        "name": {
          "type": "string"
        },
        "ownership_model": {
          "type": "string"
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "current_status": {
          "enum": [
            "planning_only",
            "missing_adapter",
            "missing_runner",
            "missing_owner_review"
          ]
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    },
    "workflow_test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_id",
        "workflow",
        "required_observation",
        "required_artifacts",
        "current_status"
      ],
      "properties": {
        "test_id": {
          "type": "string",
          "pattern": "^UI-SURFACE-TEST-[A-Z0-9_-]+$"
        },
        "workflow": {
          "type": "string"
        },
        "required_observation": {
          "type": "string"
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "current_status": {
          "enum": [
            "planning_only",
            "missing_reference_shell",
            "missing_simulated_renderer",
            "missing_fault_injection",
            "missing_latency_trace"
          ]
        }
      }
    },
    "failure_recovery_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case",
        "safe_result",
        "missing_evidence"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^UI-SURFACE-FAILURE-[A-Z0-9_-]+$"
        },
        "case": {
          "type": "string"
        },
        "safe_result": {
          "type": "string"
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    },
    "security_identity_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary_id",
        "boundary",
        "enforced_identity",
        "unsafe_if_missing",
        "missing_evidence"
      ],
      "properties": {
        "boundary_id": {
          "type": "string",
          "pattern": "^UI-SURFACE-BOUNDARY-[A-Z0-9_-]+$"
        },
        "boundary": {
          "type": "string"
        },
        "enforced_identity": {
          "type": "string"
        },
        "unsafe_if_missing": {
          "type": "string"
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    },
    "evidence_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_id",
        "blocker",
        "needed_for",
        "missing_evidence"
      ],
      "properties": {
        "blocker_id": {
          "type": "string",
          "pattern": "^UI-SURFACE-BLOCKER-[A-Z0-9_-]+$"
        },
        "blocker": {
          "type": "string"
        },
        "needed_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "string"
        }
      }
    }
  }
}
