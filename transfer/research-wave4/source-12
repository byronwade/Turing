def update_validator() -> None:
    path = ROOT / "tools/validate_blueprint.py"
    text = path.read_text(encoding="utf-8")
    match = re.search(r"^DETAILED_BOOKS = (.+)$", text, flags=re.MULTILINE)
    if not match:
        raise RuntimeError("DETAILED_BOOKS assignment not found")
    books = ast.literal_eval(match.group(1))
    books.update(
        {
            "technology-stack": [item["filename"] for item in TECHNOLOGY_CHAPTERS] + ["README.md"],
            "plugins": [item["filename"] for item in PLUGIN_CHAPTERS] + ["README.md"],
            "embedding": [item["filename"] for item in EMBEDDING_CHAPTERS] + ["README.md"],
        }
    )
    text = text[: match.start(1)] + repr(books) + text[match.end(1) :]

    required_anchor = '    RESEARCH / "performance-security-developer-expansion-audit-2026-07.md",'
    required_addition = (
        required_anchor
        + '\n    RESEARCH / "technology-stack-servo-and-embedding-study-2026-07.md",'
        + '\n    RESEARCH / "chrome-extension-demand-and-first-party-plugin-study-2026-07.md",'
    )
    if "technology-stack-servo-and-embedding-study-2026-07.md" not in text:
        if required_anchor not in text:
            raise RuntimeError("validator research anchor not found")
        text = text.replace(required_anchor, required_addition, 1)

    text = text.replace("if len(markdown_files) < 204:", "if len(markdown_files) < 230:")
    text = text.replace("expected at least 204 Markdown documents", "expected at least 230 Markdown documents")
    text = text.replace('"19 detailed engineering books, 46 requirements, 40 risks, "', '"22 detailed engineering books, 46 requirements, 40 risks, "')
    path.write_text(text, encoding="utf-8")


def verify_generated_topology() -> None:
    expected: list[Path] = []
    for directory, chapters in (
        ("technology-stack", TECHNOLOGY_CHAPTERS),
        ("plugins", PLUGIN_CHAPTERS),
        ("embedding", EMBEDDING_CHAPTERS),
    ):
        expected.append(ROOT / "docs" / directory / "README.md")
        expected.extend(ROOT / "docs" / directory / item["filename"] for item in chapters)
    expected.extend(
        [
            ROOT / "docs/research/technology-stack-servo-and-embedding-study-2026-07.md",
            ROOT / "docs/research/chrome-extension-demand-and-first-party-plugin-study-2026-07.md",
        ]
    )
    missing = [str(path.relative_to(ROOT)) for path in expected if not path.is_file()]
    if missing:
        raise RuntimeError("generated files missing: " + ", ".join(missing))

    for path in expected:
        if path.suffix != ".md":
            continue
        value = path.read_text(encoding="utf-8")
        if "\r" in value:
            raise RuntimeError(f"CR line ending in {path}")
        for line_number, line in enumerate(value.splitlines(), 1):
            trailing = line[len(line.rstrip(" \t")) :]
            if trailing and trailing != "  ":
                raise RuntimeError(f"accidental trailing whitespace: {path}:{line_number}")


