def clean(text: str) -> str:
    return dedent(text).strip() + "\n"


def write(path: str, content: str) -> None:
    target = ROOT / path
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(clean(content), encoding="utf-8")


def replace_once(path: str, old: str, new: str) -> None:
    target = ROOT / path
    text = target.read_text(encoding="utf-8")
    if new in text:
        return
    if old not in text:
        raise RuntimeError(f"{path}: expected replacement anchor not found: {old!r}")
    target.write_text(text.replace(old, new, 1), encoding="utf-8")


def append_once(path: str, marker: str, section: str) -> None:
    target = ROOT / path
    text = target.read_text(encoding="utf-8")
    if marker in text:
        return
    target.write_text(text.rstrip() + "\n\n" + clean(section), encoding="utf-8")


def insert_before(path: str, anchor: str, marker: str, section: str) -> None:
    target = ROOT / path
    text = target.read_text(encoding="utf-8")
    if marker in text:
        return
    if anchor not in text:
        raise RuntimeError(f"{path}: insertion anchor not found: {anchor!r}")
    text = text.replace(anchor, clean(section) + "\n" + anchor, 1)
    target.write_text(text, encoding="utf-8")


def bullets(items: list[str]) -> str:
    return "\n".join(f"- {item}" for item in items)


def chapter(book: str, item: dict[str, object], overview: str, related: list[tuple[str, str]]) -> str:
    source_lines = "\n".join(f"- [{name}]({url})" for name, url in item["sources"])
    related_lines = "\n".join(f"- [{name}]({url})" for name, url in related)
    return f"""# {item['title']}

Status: detailed research and design baseline  
Owner: {item['owner']}  
Book index: [{book.replace('-', ' ').title()}](README.md)  
Canonical overview: [Turing Blueprint](../blueprint-v1/README.md)

## Purpose

{item['purpose']}

This chapter is research and design, not an implementation, compatibility, security, performance, or support claim.

## Program position

{overview}

## Proposed decisions

{bullets(item['decisions'])}

## Architecture and interface contract

{bullets(item['architecture'])}

## Security, privacy, performance, and maintenance risks

{bullets(item['risks'])}

## Falsifiable experiments

{bullets(item['experiments'])}

Every experiment records the source commit, toolchain, platform, hardware, build flags, supported feature set, security settings, process topology, page or API corpus, sample count, raw samples, failures, unsupported cases, confidence, and revisit trigger. A microbenchmark cannot decide a security boundary or a public compatibility promise.

## Required evidence before adoption

- normative or upstream behavior source;
- exact dependency or protocol revision;
- license and provenance review;
- threat model and least-authority boundary;
- fuzz, malformed-input, cancellation, timeout, OOM, and recovery coverage;
- compatibility and accessibility consequences;
- startup, memory, CPU, latency, energy, binary, package, and maintenance cost;
- replacement or rollback plan;
- owning ADR, requirement, risk, work package, and support statement updates.

## Primary sources

{source_lines or "- See the book research report and Blueprint bibliography."}

## Related Turing documentation

{related_lines}

## Change discipline

A proposal becomes normative only when the owning Blueprint chapters, ADRs, requirements, risks, work packages, machine registries, tests, and support statements change together.
"""


def book_index(title: str, directory: str, description: str, chapters: list[dict[str, object]],
               principles: list[str], related: list[tuple[str, str]]) -> str:
    order = "\n".join(
        f"{index}. [{item['title']}]({item['filename']})"
        for index, item in enumerate(chapters, 1)
    )
    related_lines = "\n".join(f"- [{name}]({url})" for name, url in related)
    return f"""# {title}

Status: detailed research and design baseline  
Owner: architecture, security, developer experience, and subsystem maintainers

{description}

This book does not assert that Turing currently implements or leads in any capability described here.

## Reading order

{order}

## Non-negotiable principles

{bullets(principles)}

## Decision method

Every framework, API, plug-in capability, compatibility surface, binding, or embedding feature moves through:

1. user or developer need;
2. primary-source and standards research;
3. alternatives and threat model;
4. minimal prototype;
5. correctness and conformance evidence;
6. security, privacy, accessibility, and abuse review;
7. performance, memory, energy, binary, package, and operational measurement;
8. maintenance and replacement analysis;
9. accepted ADR and versioned support commitment.

## Related material

{related_lines}
"""


